# Google Gemini
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash

# Cortex XSIAM tenant
# Use the api-* subdomain for direct REST API calls (writes)
CORTEX_URL=https://api-<tenant>.xdr.us.redacted.example.com
CORTEX_API_KEY=<your-api-key-value>
CORTEX_API_ID=<your-api-key-id>

# MCP server — Cortex MCP Server already running locally
MCP_SERVER_URL=http://localhost:8888/api/v1/stream/mcp

# State tracking
STATE_DB_PATH=./data/processed_cases.db

# Agent behavior
POLL_INTERVAL_SECONDS=300
MAX_CASES_PER_POLL=50
LOG_LEVEL=INFO

# Case filters (all optional — leave blank to use defaults)
# CASE_STATUSES=New,Under Investigation   # default: New + Under Investigation
# CASE_SEVERITIES=high,critical           # default: all severities
# CASE_DOMAIN=SECURITY                    # default: all domains
# CASE_LOOKBACK_HOURS=24                  # cases created in last N hours (default: all time)
# CASE_LAST_UPDATE_HOURS=24              # cases modified in last N hours — use this to catch recently-assigned cases
# CASE_ASSIGNEE_EMAIL=analyst@company.com # server-side filter: assigned_user (email)
# CASE_ASSIGNEE_NAME=John Smith           # server-side filter: assigned_user_pretty (display name)
